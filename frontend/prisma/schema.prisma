generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  OWNER
  ADMIN
  USER
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  password      String
  role          GlobalRole     @default(USER)
  createdAt     DateTime       @default(now())
  sessions      Session[]
  serverAccess  ServerAccess[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ServerAccess {
  id          String   @id @default(cuid())
  userId      String
  serverId    String
  permissions String[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([userId, serverId])
}

model Server {
  id              String         @id @default(cuid())
  name            String
  description     String?
  type            String
  mcVersion       String
  containerId     String?        @unique
  containerName   String         @unique
  rconPort        Int
  rconPassword    String
  gamePort        Int
  pluginPort      Int            @default(3000)
  memory          String         @default("2G")
  javaVersion     String         @default("21")
  dataPath        String
  autoStart       Boolean        @default(false)
  pluginInstalled Boolean        @default(false)
  createdAt       DateTime       @default(now())
  tasks           Task[]
  access          ServerAccess[]
}

model Task {
  id        String   @id @default(cuid())
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name      String
  cron      String
  commands  String[]
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}
