{
  "name": "fleetpanel",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted Minecraft multi-server management panel with Docker orchestration, granular permissions and historical monitoring. Fork of OPanel.",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "pnpm prelaunch && next dev --turbopack -p 3001",
    "build": "pnpm prelaunch && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prelaunch": "node scripts/prelaunch",
    "force-prelaunch": "node scripts/prelaunch force",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
