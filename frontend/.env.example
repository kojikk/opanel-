DATABASE_URL=postgresql://opanel:opanel@localhost:5432/opanel
JWT_SECRET=change-this-to-a-secure-random-string
SERVERS_BASE_PATH=../servers
# Explicit path to a single plugin JAR (optional, overrides auto-discovery)
OPANEL_PLUGIN_JAR_PATH=
# Directory with built plugin JARs (auto-discovers by server type + version)
# Defaults to ../plugin/build/libs
OPANEL_PLUGIN_BUILD_DIR=
NEXT_TELEMETRY_DISABLED=1
